{
  "browser": "chromium",
  "headless": false,
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "baseURL": "http://localhost:3000",
  "timeout": {
    "action": 5000,
    "navigation": 60000
  },
  "console": {
    "level": "info"
  },
  "capabilities": ["vision"],
  "outputMode": "stdout",
  "saveTrace": true,
  "saveVideo": false
}